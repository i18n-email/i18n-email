{
  "name": "i18n-email",
  "version": "0.5.0",
  "type": "module",
  "description": "Translate transactional emails into any language using AI models.",
  "author": "Dan Zabrotski",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i18n-email/i18n-email.git"
  },
  "bugs": {
    "url": "https://github.com/i18n-email/i18n-email/issues"
  },
  "homepage": "https://github.com/i18n-email/i18n-email",
  "keywords": [
    "i18n",
    "email",
    "translation",
    "react",
    "react-email",
    "localization"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@react-email/render": "^1",
    "node-html-parser": "^6"
  },
  "peerDependencies": {
    "@tanstack/ai": ">=0.8",
    "ai": ">=4",
    "openai": ">=4",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "@tanstack/ai": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3",
    "@tanstack/ai": "^0.8.1",
    "@types/bun": "latest",
    "@types/react": "^19",
    "ai": "^6",
    "openai": "^4",
    "tsup": "^8",
    "typescript": "^5"
  }
}
