{
  "name": "@i18n-email/resend",
  "version": "0.1.0",
  "type": "module",
  "description": "Resend integration for i18n-email - adds locale to emails.send()",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "i18n-email": ">=0.2.0",
    "react": ">=18",
    "resend": ">=4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "i18n-email": "workspace:*",
    "resend": "^6",
    "tsup": "^8",
    "typescript": "^5"
  }
}
