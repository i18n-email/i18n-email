{
  "name": "@i18n-email/resend",
  "version": "0.2.0",
  "type": "module",
  "description": "Resend integration for i18n-email - adds locale to emails.send()",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i18n-email/i18n-email.git",
    "directory": "packages/resend"
  },
  "bugs": {
    "url": "https://github.com/i18n-email/i18n-email/issues"
  },
  "homepage": "https://i18n.email/docs/integrations/resend",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Dan Zabrotski",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "i18n",
    "email",
    "translation",
    "resend",
    "react-email",
    "localization"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "i18n-email": ">=0.2.0",
    "react": ">=18",
    "resend": ">=4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19",
    "i18n-email": "workspace:*",
    "resend": "^6",
    "tsup": "^8",
    "typescript": "^5"
  }
}
